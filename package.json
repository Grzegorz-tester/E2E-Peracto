{
  "name": "e2e",
  "version": "1.0.0",
  "description": "Greg Hajduk E2E automation framework using Playwright and Cucumber.",
  "main": "index.js",
  "author": "Grzegorz Hajduk",
  "license": "ISC",
"scripts": {
  "clean": "rimraf dist reports",
  "precucumber": "rimraf reports && mkdir reports",
  "transpile": "rimraf dist && babel --extensions .ts --out-dir dist src",
  "cucumber-compile": "yarn transpile && cucumber-js src/features/Indespension_features --require dist/steps/**/*.js --format json:reports/report.json",
  "cucumber": "cross-env COMMON_CONFIG_FILE=env/common.env yarn cucumber-compile",
  "postcucumber": "cross-env COMMON_CONFIG_FILE=env/common.env ts-node ./src/reporter/cucumber-report.ts",
  "test": "yarn cucumber && yarn postcucumber"
}
,
  "devDependencies": {
    "@babel/cli": "^7.23.4",
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/preset-typescript": "^7.23.3",
    "@cucumber/cucumber": "^10.0.1",
    "@playwright/test": "^1.40.1",
    "@types/node": "^20.10.3",
    "dotenv": "^16.4.1",
    "playwright": "^1.40.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2",
    "cross-env": "^7.0.3"
  },
  "dependencies": {
    "cucumber-html-reporter": "^7.1.1"
  }
}

