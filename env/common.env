# ================== COMMON AUTOMATION SETTINGS ==================
UI_AUTOMATION_BROWSER='chromium'         # Options: 'chromium', 'firefox', 'webkit'
UI_AUTOMATION_HOST=staging               # Logical host/environment name
SCREENSHOT_PATH=./reports/screenshots/   # Directory for screenshots
VIDEO_PATH=./reports/videos/             # Directory for video recordings
JSON_REPORT_FILE=./reports/report.json   # Path for JSON report output
HTML_REPORT_FILE=./reports/cucumber-html-report.html # Path for HTML report output
HEADLESS=false                          # Run browser in headless mode (true/false)
SCRIPT_TIMEOUT=20000                    # Script timeout in milliseconds
PARALLEL=1                              # Number of parallel test runners
RETRY=1                                 # Number of retries for failed tests

