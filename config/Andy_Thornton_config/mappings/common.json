  "By Venue menu item": "//p[@data-testid='navigation-bar__items-item' and contains(text(), 'By Venue')]",
  "Antiques menu item": "//p[@data-testid='navigation-bar__items-item' and contains(text(), 'Antiques')]",
  "Interior Fittings menu item": "//p[@data-testid='navigation-bar__items-item' and contains(text(), 'Interior Fittings')]",
