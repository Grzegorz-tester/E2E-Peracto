  "Inspiration menu item": "//p[@data-testid='navigation-bar__items-item' and contains(text(), 'Inspiration')]",
  "More menu item": "//p[@data-testid='navigation-bar__items-item' and contains(text(), 'More')]",
  "magnifier glass": "[data-testid='search__form__search-button']",
  "search results": "[data-testid='search__hits']",
